{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "packageName": "com.claude.codebot",
  "developer": {
    "name": "Claude Code Bot",
    "websiteUrl": "https://www.anthropic.com",
    "privacyUrl": "https://www.anthropic.com/privacy",
    "termsOfUseUrl": "https://www.anthropic.com/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "Claude Code Bot",
    "full": "Claude AI Code Assistant for Microsoft Teams"
  },
  "description": {
    "short": "AI-powered coding assistant",
    "full": "Get intelligent code explanations, bug fixes, code reviews, and programming help directly in Microsoft Teams using Claude AI by Anthropic."
  },
  "accentColor": "#6366F1",
  "bots": [
    {
      "botId": "${{BOT_ID}}",
      "scopes": [
        "personal",
        "team",
        "groupchat"
      ],
      "supportsFiles": true,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": [
            "personal",
            "team",
            "groupchat"
          ],
          "commands": [
            {
              "title": "help",
              "description": "Show available commands and how to use the bot"
            },
            {
              "title": "examples",
              "description": "Show example questions you can ask"
            }
          ]
        }
      ]
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": [
    "*.anthropic.com"
  ]
}
